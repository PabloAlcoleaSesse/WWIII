<!-- Leaflet JS (must load before our script) -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script define:vars={{ CONFLICTS, MAP_MARKERS, IDEO_LABEL, GEO_LABEL, INTENSITY_LABEL }}>

/* ── UTC CLOCK ── */
function updateClock() {
  const d = new Date();
  const pad = n => String(n).padStart(2,'0');
  const timeStr = `${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}`;
  const shortStr = `${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())} UTC`;
  const el = document.getElementById('utc-clock');
  const mt = document.getElementById('map-time');
  if (el) el.textContent = timeStr;
  if (mt) mt.textContent = shortStr;
}
setInterval(updateClock, 1000);
updateClock();

/* ── LAST UPDATE ── */
let lastUpdateMin = 4;
setInterval(() => {
  lastUpdateMin = lastUpdateMin >= 59 ? 1 : lastUpdateMin + 1;
  const el = document.getElementById('last-update');
  if (el) el.textContent = `hace ${lastUpdateMin} min`;
}, 60000);

/* ── BREAKING TICKER ── */
const tickerItems = document.querySelectorAll('.breaking-ticker-item');
let tickerIdx = 0;
if (tickerItems.length > 1) {
  setInterval(() => {
    tickerItems[tickerIdx].classList.remove('active');
    tickerIdx = (tickerIdx + 1) % tickerItems.length;
    tickerItems[tickerIdx].classList.add('active');
  }, 5000);
}

/* ── MOBILE MENU ── */
const menuToggle = document.getElementById('menu-toggle');
const nav = document.getElementById('nav');
if (menuToggle && nav) {
  menuToggle.addEventListener('click', () => nav.classList.toggle('open'));
  nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => nav.classList.remove('open')));
}

/* ── MODAL ── */
const overlay = document.getElementById('modal-overlay');
const modalClose = document.getElementById('modal-close');

function openModal(key) {
  const c = CONFLICTS[key];
  if (!c) return;
  document.getElementById('modal-title').textContent = c.title;
  document.getElementById('modal-meta').innerHTML =
    `<span>INFORME ${c.id}</span><span>· ${c.region}</span><span>· ${c.type}</span>` +
    `<span class="intensity-badge ${c.intensity}" style="margin-left:auto">${INTENSITY_LABEL[c.intensity]}</span>`;
  document.getElementById('modal-summary').textContent = c.summary;
  const sc = document.getElementById('modal-sources');
  sc.innerHTML = '';
  c.sources.forEach(s => {
    const d = document.createElement('div');
    d.className = 'source-card';
    d.innerHTML =
      `<div class="source-head"><div class="source-name">${s.name}</div>` +
      `<div class="source-tags"><span class="tag ${s.ideo}">${IDEO_LABEL[s.ideo]}</span>` +
      `<span class="tag ${s.geo}">${GEO_LABEL[s.geo]}</span></div></div>` +
      `<div class="source-headline">"${s.headline}"</div>` +
      `<div class="source-take">${s.take}</div>`;
    sc.appendChild(d);
  });
  overlay.classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  overlay.classList.remove('active');
  document.body.style.overflow = '';
}

if (modalClose) modalClose.addEventListener('click', closeModal);
if (overlay) overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

/* ── CONFLICTS GRID ── */
const grid = document.getElementById('conflicts-grid');
if (grid) {
  Object.entries(CONFLICTS).forEach(([key, c]) => {
    const card = document.createElement('div');
    card.className = `conflict-card ${c.intensity}`;
    card.innerHTML =
      `<div class="conflict-card-head">` +
      `<span class="conflict-id">${c.id}</span>` +
      `<span class="intensity-badge ${c.intensity}">${INTENSITY_LABEL[c.intensity]}</span></div>` +
      `<h4>${c.title}</h4>` +
      `<p>${c.summary.substring(0,140)}…</p>` +
      `<div class="conflict-meta"><span>${c.region} · ${c.type}</span><span class="arrow">VER BRIEFING →</span></div>`;
    card.addEventListener('click', () => openModal(key));
    grid.appendChild(card);
  });
}

/* ── CONTINENTAL TABS ── */
const tabsBar = document.getElementById('tabs-bar');
if (tabsBar) {
  tabsBar.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      tabsBar.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = btn.dataset.tab;
      document.querySelectorAll('.tab-content').forEach(c => {
        c.classList.toggle('active', c.dataset.content === tab);
      });
    });
  });
}

/* ── FORM ── */
const form = document.getElementById('briefing-form');
const formMsg = document.getElementById('form-msg');
if (form && formMsg) {
  form.addEventListener('submit', e => {
    e.preventDefault();
    const name = document.getElementById('form-name').value.trim();
    const email = document.getElementById('form-email').value.trim();
    if (!name || name.length < 2) {
      formMsg.className = 'form-msg error'; formMsg.textContent = 'Nombre no válido'; return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      formMsg.className = 'form-msg error'; formMsg.textContent = 'Correo no válido'; return;
    }
    formMsg.className = 'form-msg success';
    formMsg.textContent = 'Suscripción confirmada · revisa tu bandeja';
    form.reset();
    setTimeout(() => { formMsg.className = 'form-msg'; formMsg.textContent = ''; }, 5000);
  });
}

/* ── LEAFLET MAP ── */
function initMap() {
  if (typeof L === 'undefined') { setTimeout(initMap, 100); return; }

  const map = L.map('leaflet-map', {
    center: [20, 15],
    zoom: 2,
    minZoom: 2,
    maxZoom: 6,
    zoomControl: true,
    maxBounds: [[-85, -180], [85, 180]],
    maxBoundsViscosity: 1.0,
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
    subdomains: 'abcd',
    maxZoom: 19,
  }).addTo(map);

  const COLOR = { critical: '#a83232', high: '#d4731c', moderate: '#c9a961' };
  const filters = { intensity: 'all', type: 'all', region: 'all' };
  const instances = {};

  MAP_MARKERS.forEach(m => {
    const color = COLOR[m.intensity];
    const icon = L.divIcon({
      className: '',
      html: `<div style="position:relative;width:14px;height:14px;color:${color}">` +
            `<div class="lf-ring" style="color:${color}"></div>` +
            `<div class="lf-core" style="background:${color};box-shadow:0 0 0 2px rgba(255,255,255,.85),0 0 14px ${color},0 0 30px ${color}"></div>` +
            `</div>`,
      iconSize: [14, 14],
      iconAnchor: [7, 7],
      popupAnchor: [0, -16],
    });

    const marker = L.marker([m.lat, m.lng], { icon });

    const popupHtml =
      `<div class="map-popup">` +
      `<div class="map-popup-id">${m.tooltipId}</div>` +
      `<div class="map-popup-title">${m.tooltipTitle}</div>` +
      `<div class="map-popup-meta">${m.tooltipMeta}</div>` +
      `<div class="map-popup-action" data-key="${m.key}">CLICK PARA BRIEFING →</div>` +
      `</div>`;

    marker.bindPopup(popupHtml, { maxWidth: 260, minWidth: 220, closeButton: true });
    marker.addTo(map);

    marker.on('popupopen', () => {
      document.querySelectorAll('.map-popup-action').forEach(btn => {
        btn.addEventListener('click', () => { map.closePopup(); openModal(btn.dataset.key); });
      });
    });

    instances[m.key] = { marker, data: m };
  });

  map.on('mousemove', e => {
    const lat = Math.abs(e.latlng.lat).toFixed(1);
    const lng = Math.abs(e.latlng.lng).toFixed(1);
    const latH = e.latlng.lat >= 0 ? 'N' : 'S';
    const lngH = e.latlng.lng >= 0 ? 'E' : 'W';
    const el = document.getElementById('map-coords');
    if (el) el.innerHTML = `PROYECCIÓN: MERCATOR · LAT ${lat}°${latH} · LON ${lng}°${lngH} · ACT: <span id="map-time">${document.getElementById('map-time')?.textContent || '--:-- UTC'}</span>`;
  });

  document.querySelectorAll('.filter-chips').forEach(group => {
    const fk = group.dataset.filter;
    group.querySelectorAll('.chip').forEach(chip => {
      chip.addEventListener('click', () => {
        group.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        filters[fk] = chip.dataset.value;
        Object.values(instances).forEach(({ marker, data }) => {
          const show =
            (filters.intensity === 'all' || filters.intensity === data.intensity) &&
            (filters.type === 'all' || filters.type === data.type) &&
            (filters.region === 'all' || filters.region === data.region);
          if (show) { if (!map.hasLayer(marker)) marker.addTo(map); }
          else { if (map.hasLayer(marker)) map.removeLayer(marker); }
        });
      });
    });
  });
}

initMap();
</script>

